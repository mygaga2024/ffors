# ============================================================
# FFORS .gitignore — 隐私与安全拦截
# 遵循 DEVELOPMENT_PROTOCOL.md §2 & §7
# ============================================================

# --- 敏感数据 & 环境变量 ---
.env
.env.*
!.env.example

# --- 真实业务数据目录 ---
/data/*
!/data/seed_ports.json
/uploads/
/storage/

# --- 运行日志 ---
/logs/

# --- Python 缓存 ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- 虚拟环境 ---
venv/
.venv/
env/

# --- 测试缓存 ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- IDE 配置 ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# --- Docker 运行时产物 ---
docker-compose.override.yml
