# ============================================================
# FFORS 环境变量模板
# 复制为 .env 并填写真实值，严禁将 .env 提交到 Git
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://ffors_user:your_password@ffors-db:5432/ffors

# --- AI Services — MiniMax (Phase 2) ---
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_GROUP_ID=your_minimax_group_id_here

# --- AI Services — Gemini (Phase 2, 备选) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Notifications — 企业微信 Webhook (Phase 2) ---
WECOM_WEBHOOK_KEY=your_wecom_webhook_key_here

# --- Proxy (for overseas API calls) ---
HTTP_PROXY=
HTTPS_PROXY=

# --- Paths ---
DATA_DIR=/app/data
LOG_DIR=/app/logs
