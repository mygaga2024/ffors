# ============================================================
# FFORS 环境变量模板
# 复制为 env 并填写真实值，严禁将 env 文件提交到 Git
# ============================================================

# --- Database ---
# 修改此密码即可，docker-compose 会自动将其注入数据库和连接串
DB_PASSWORD=your_password

# --- AI Services — MiniMax ---
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_GROUP_ID=your_minimax_group_id_here

# --- AI Services — Gemini (备选) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Notifications — WeCom Alert Bot ---
WECOM_WEBHOOK_KEY=your_wecom_webhook_key

# --- Bot Webhook Auth (Phase 3) ---
# 钉钉机器人验签 (HmacSHA256)
DINGTALK_APP_SECRET=your_dingtalk_app_secret

# 企业微信机器人接收回调配置 (预留)
WECOM_BOT_TOKEN=your_wecom_bot_token
WECOM_ENCODING_AES_KEY=your_wecom_aes_key_here

# --- Proxy (for overseas API calls) ---
HTTP_PROXY=
HTTPS_PROXY=

# --- Paths ---
DATA_DIR=/app/data
LOG_DIR=/app/logs
